[bar/bar]
enable-ipc=true
height = 30
width = 100%
offset-x = 1%
offset-y = 1%
padding = 5
bottom = false
radius-top = 0
radius-bottom = 10

background = ${colors.background}
;background = ${colors.primary}
foreground = ${colors.foreground}
;border-size = 10

border-top-size = 0
border-left-size = 17
border-right-size = 17
border-bottom-size = 0
border-color = #0000

line-size = 2

font-0=SF Mono Nerd Font:style=Regular:size=10;2
font-1=SF Mono Nerd Font:style=Semibold:size=10;2
font-2=Material-Design-Iconic-Font:size=13;4
font-3=font\-logos:size=10;2
font-4=FontAwesome5Brands:size=11;1
font-5=IPAGothic:size=11;3

modules-right = spotify systray pulseaudio time

; i3
modules-left = i3 xwindow
scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev
wm-restack = i3


