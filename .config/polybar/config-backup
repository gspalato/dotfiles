[module/launcher]
type=custom/text
content = ÔĄÉ
content-margin = 1
click-left=launcher
;The script above is to be found here : https://github.com/ngynLk/scripts

[module/updates]
type=custom/script
exec = yay -Qu | wc -l
exec-if = [[ $(yay -Qu | wc -l) != 0 ]]
format = Óźö  <label> update(s) available.
format-margin = 8
tail = true
interval = 30
click-left = alacritty -e yay -Syu

[module/systray]
type=custom
tray-position = right

[module/xwindow]
type = internal/xwindow
label = %title:0:32:...%
label-empty = Empty 
label-empty-font = 2
label-font = 2
format-margin = 0

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
format-margin = 4
index-sort = true
strip-wsnumbers = true

enable-click = true
reverse-scroll = false

label-focused = %name%
label-focused-underline = ${colors.foreground}
label-focused-padding = 2
label-focused-font = 2

label-unfocused = %name%
label-unfocused-padding = 2

label-urgent = !
label-urgent-padding = 2
label-urgent-underline = ${colors.background}
label-urgent-font = 2

ws-icon-0 = 1
ws-icon-1 = 2
ws-icon-2 = 3
ws-icon-4 = 4
ws-icon-5 = 5

[module/wlan]
type = internal/network
interface = wlp0s20u2
interval = 3.0

format-connected = Ôáę <label-connected>
label-connected = %essid%
label-connected-color1 = ${colors.color1}

format-disconnected = <label-disconnected>
label-disconnected = %ifname% disconnected
label-disconnected-color1 = ${colors.color1}

ramp-signal-0 = Óąė
ramp-signal-1 = Óąô
ramp-signal-2 = Óąö
ramp-signal-3 = Óąö
ramp-signal-4 = Óąö
ramp-signal-color1 = ${colors.color1}

[module/time]
type = internal/date
interval = 10
format-margin = 0

time = "%H:%M"
date = "%d %b"

label = %time% | %date%
label-background = ${colors.background}
label-padding = 0


[module/pulseaudio]
type = internal/pulseaudio

format-volume-margin = 0
format-volume = <ramp-volume><label-volume>
label-volume = %percentage:4:4%%
format-volume-background = ${colors.background}
format-volume-padding = 2
use-ui-max = false
interval = 5

ramp-volume-0 = "ÓĀé"
ramp-volume-1 = "ÓĀć"
ramp-volume-2 = "ÓĀź"


label-muted = "ÓĀŹ muted"   
label-muted-background = ${colors.background}
label-muted-padding = 2

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <label>
format-warn = <ramp> <label-warn>

label = %temperature-c%
label-warn = %temperature-c%
label-warn-color1 = ${colors.secondary}

ramp-0 = Ôčč
ramp-1 = ÔčČ
ramp-2 = ÓÉč

[module/powermenu]
type = custom/menu

expand-right = false

format-margin = 2
format-spacing = 2

label-open = ÓĘ¨
label-close = ÓóČ
label-separator = |

; reboot
menu-0-1 = Óźö
menu-0-1-exec = menu-open-2
; poweroff
menu-0-2 = ÓĘ¨
menu-0-2-exec = menu-open-3
; logout
menu-0-0 = Óóö
menu-0-0-exec = menu-open-1

menu-2-0 = Óźö
menu-2-0-exec = reboot

menu-3-0 = ÓĘ¨
menu-3-0-exec = poweroff

menu-1-0 = Óóö
menu-1-0-exec = i3-msg exit || openbox --exit

[module/spotify]
type = custom/script
format-margin = 0
format = ÔÜľ  <label>
label = %output:0:40:...%
exec = playerctl metadata --format '{{artist}}: {{title}}'
tail = true
interval = 1
click-left = "playerctl play-pause"

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
pseudo-transparency = false

[global/wm]
margin-top = 0
margin-bottom = 0

